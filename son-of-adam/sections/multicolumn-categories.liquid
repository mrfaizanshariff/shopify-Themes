{% comment %}
  SON OF ADAM - Multicolumn Categories Section
  Grid layout for product categories with images
{% endcomment %}

<section class="multicolumn-categories full-width section-spacing">
  {% if section.settings.heading != blank %}
    <h2 class="multicolumn-categories__heading section-title text-center">
      {{ section.settings.heading }}
    </h2>
  {% endif %}
  
  <div class="multicolumn-categories__grid grid grid-{{ section.settings.columns }}">
    {% for block in section.blocks %}
      <div class="category-card" {{ block.shopify_attributes }}>
        <a href="{{ block.settings.link }}" class="category-card__link">
          <div class="category-card__image-wrapper">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                srcset="{{ block.settings.image | image_url: width: 300 }} 300w,
                        {{ block.settings.image | image_url: width: 600 }} 600w"
                sizes="(min-width: 1024px) 25vw, (min-width: 768px) 33vw, 50vw"
                alt="{{ block.settings.image.alt | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
                class="category-card__image"
              >
            {% else %}
              <div class="category-card__placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}
            
            {% if block.settings.overlay_text != blank %}
              <div class="category-card__overlay">
                <span class="category-card__overlay-text">{{ block.settings.overlay_text }}</span>
              </div>
            {% endif %}
          </div>
          
          <div class="category-card__content">
            {% if block.settings.title != blank %}
              <h3 class="category-card__title">{{ block.settings.title }}</h3>
            {% endif %}
            
            {% if block.settings.description != blank %}
              <p class="category-card__description">{{ block.settings.description }}</p>
            {% endif %}
          </div>
        </a>
      </div>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .multicolumn-categories {
    padding-left: var(--page-margin);
    padding-right: var(--page-margin);
  }
  
  .multicolumn-categories__heading {
    margin-bottom: var(--spacing-xl);
  }
  
  .multicolumn-categories__grid {
    display: grid;
    gap: var(--grid-gutter);
  }
  
  .category-card {
    position: relative;
  }
  
  .category-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  
  .category-card__image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 100%; /* Square aspect ratio */
    overflow: hidden;
    background-color: var(--color-sea-salt);
    border-radius: 0;
  }
  
  .category-card__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }
  
  .category-card__link:hover .category-card__image {
    transform: scale(1.05);
  }
  
  .category-card__placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .category-card__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 50%, rgba(13, 28, 49, 0.8));
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: var(--spacing-md);
    opacity: 0;
    transition: opacity var(--transition-base);
  }
  
  .category-card__link:hover .category-card__overlay {
    opacity: 1;
  }
  
  .category-card__overlay-text {
    font-family: var(--font-header);
    font-size: var(--font-size-small);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-white);
  }
  
  .category-card__content {
    padding: var(--spacing-md) 0;
    text-align: center;
  }
  
  .category-card__title {
    font-family: var(--font-header);
    font-size: 20px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 var(--spacing-xs) 0;
    color: var(--color-oxford-blue);
    transition: color var(--transition-fast);
  }
  
  .category-card__link:hover .category-card__title {
    color: var(--color-harvest-gold);
  }
  
  .category-card__description {
    font-family: var(--font-body);
    font-size: var(--font-size-small);
    line-height: var(--line-height-relaxed);
    color: var(--color-dim-grey);
    margin: 0;
  }
  
  /* Responsive */
  @media (max-width: 767px) {
    .multicolumn-categories__grid {
      grid-template-columns: 1fr !important;
    }
  }
  
  @media (min-width: 768px) and (max-width: 1023px) {
    .multicolumn-categories__grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Multicolumn Categories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Browse Categories"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (Desktop)",
      "options": [
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        }
      ],
      "default": "4"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Recommended: Square image (800x800px)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category Name"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "overlay_text",
          "label": "Overlay Text (on hover)",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Multicolumn Categories",
      "category": "Collection",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Beard Care",
            "description": "Oils, balms & grooming tools"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Face Care",
            "description": "Cleansers, moisturizers & serums"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Body Care",
            "description": "Soaps, scrubs & body oils"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Fragrance",
            "description": "Colognes & body sprays"
          }
        }
      ]
    }
  ]
}
{% endschema %}