{% comment %}
  SON OF ADAM - Premium Footer
  Oxford Blue background with multi-column layout
{% endcomment %}

<footer class="footer full-width bg-oxford-blue" role="contentinfo">
  <div class="footer__container">
    <div class="footer__grid">
      {%- comment -%} Brand Column {%- endcomment -%}
      <div class="footer__column footer__column--brand">
        <div class="footer__logo">
          {% if section.settings.logo != blank %}
            <img
              src="{{ section.settings.logo | image_url: width: 200 }}"
              alt="{{ shop.name }}"
              width="{{ section.settings.logo.width }}"
              height="{{ section.settings.logo.height }}"
              loading="lazy"
              class="footer__logo-image"
            >
          {% else %}
            <span class="footer__logo-text">{{ shop.name }}</span>
          {% endif %}
        </div>
        
        {% if section.settings.tagline != blank %}
          <p class="footer__tagline">{{ section.settings.tagline }}</p>
        {% endif %}
        
        {% if section.settings.show_social %}
          <div class="footer__social">
            {% if section.settings.social_facebook != blank %}
              <a href="{{ section.settings.social_facebook }}" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {% endif %}
            
            {% if section.settings.social_instagram != blank %}
              <a href="{{ section.settings.social_instagram }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="2"/>
                  <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/>
                  <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/>
                </svg>
              </a>
            {% endif %}
            
            {% if section.settings.social_twitter != blank %}
              <a href="{{ section.settings.social_twitter }}" class="footer__social-link" aria-label="Twitter" target="_blank" rel="noopener">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
      
      {%- comment -%} Shop Links {%- endcomment -%}
      {% if section.settings.menu_shop.links.size > 0 %}
        <div class="footer__column">
          <h3 class="footer__heading">Shop</h3>
          <ul class="footer__menu">
            {% for link in section.settings.menu_shop.links %}
              <li class="footer__menu-item">
                <a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
      
      {%- comment -%} About Links {%- endcomment -%}
      {% if section.settings.menu_about.links.size > 0 %}
        <div class="footer__column">
          <h3 class="footer__heading">About</h3>
          <ul class="footer__menu">
            {% for link in section.settings.menu_about.links %}
              <li class="footer__menu-item">
                <a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
      
      {%- comment -%} Support Links {%- endcomment -%}
      {% if section.settings.menu_support.links.size > 0 %}
        <div class="footer__column">
          <h3 class="footer__heading">Support</h3>
          <ul class="footer__menu">
            {% for link in section.settings.menu_support.links %}
              <li class="footer__menu-item">
                <a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    </div>
    
    {%- comment -%} Footer Bottom {%- endcomment -%}
    <div class="footer__bottom">
      <div class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </div>
      
      {% if section.settings.show_payment_icons %}
        <div class="footer__payment">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    background-color: var(--color-oxford-blue);
    color: var(--color-white);
    padding: var(--spacing-4xl) 0 var(--spacing-xl) 0;
  }
  
  .footer__container {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }
  
  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--spacing-3xl);
    margin-bottom: var(--spacing-3xl);
    padding-bottom: var(--spacing-3xl);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  /* Brand Column */
  .footer__column--brand {
    max-width: 350px;
  }
  
  .footer__logo {
    margin-bottom: var(--spacing-md);
  }
  
  .footer__logo-image {
    max-height: 40px;
    width: auto;
  }
  
  .footer__logo-text {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 400;
    color: var(--color-white);
    letter-spacing: 0.05em;
  }
  
  .footer__tagline {
    font-family: var(--font-body);
    font-size: var(--font-size-small);
    line-height: var(--line-height-loose);
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: var(--spacing-lg);
  }
  
  .footer__social {
    display: flex;
    gap: var(--spacing-sm);
  }
  
  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-white);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    transition: all var(--transition-fast);
  }
  
  .footer__social-link:hover {
    color: var(--color-harvest-gold);
    border-color: var(--color-harvest-gold);
    transform: translateY(-2px);
  }
  
  /* Menu Columns */
  .footer__heading {
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-white);
    margin-bottom: var(--spacing-md);
  }
  
  .footer__menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .footer__menu-item {
    margin-bottom: var(--spacing-xs);
  }
  
  .footer__menu-link {
    font-family: var(--font-body);
    font-size: var(--font-size-small);
    line-height: var(--line-height-loose);
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  
  .footer__menu-link:hover {
    color: var(--color-harvest-gold);
  }
  
  /* Footer Bottom */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing-md);
  }
  
  .footer__copyright {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(255, 255, 255, 0.6);
  }
  
  .footer__payment {
    display: flex;
    gap: var(--spacing-xs);
    flex-wrap: wrap;
  }
  
  .footer__payment-icon {
    height: 24px;
    width: auto;
    opacity: 0.7;
    transition: opacity var(--transition-fast);
  }
  
  .footer__payment-icon:hover {
    opacity: 1;
  }
  
  /* Responsive */
  @media (max-width: 1023px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-2xl);
    }
    
    .footer__column--brand {
      grid-column: 1 / -1;
      max-width: 100%;
    }
  }
  
  @media (max-width: 767px) {
    .footer {
      padding: var(--spacing-3xl) 0 var(--spacing-lg) 0;
    }
    
    .footer__grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
      margin-bottom: var(--spacing-xl);
      padding-bottom: var(--spacing-xl);
    }
    
    .footer__bottom {
      flex-direction: column;
      text-align: center;
    }
    
    .footer__payment {
      justify-content: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Grooming as timeless as man."
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Icons",
      "default": true
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter URL"
    },
    {
      "type": "header",
      "content": "Menus"
    },
    {
      "type": "link_list",
      "id": "menu_shop",
      "label": "Shop Menu"
    },
    {
      "type": "link_list",
      "id": "menu_about",
      "label": "About Menu"
    },
    {
      "type": "link_list",
      "id": "menu_support",
      "label": "Support Menu"
    },
    {
      "type": "header",
      "content": "Payment Icons"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ]
}
{% endschema %}
